{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrayLnks",
  "version": "0.1.0",
  "identifier": "com.traylnks.launcher",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "TrayLnks Settings",
        "width": 760,
        "height": 560,
        "visible": false,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
